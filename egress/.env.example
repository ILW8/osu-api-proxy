# Prerequisites:
# 1. Create users.map with per-user secrets (see entry/users.map.example)
# 2. Create Docker secret: docker secret create users_map ./users.map

# Optional: container registry prefix (default: localhost:5000)
# Examples: ghcr.io/yourusername, docker.io/yourusername
REGISTRY=localhost:5000

# Optional: Grafana admin password for the monitoring stack (default: admin)
GRAFANA_ADMIN_PASSWORD=admin
