{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Entry — Request Rate",
      "description": "Total HTTP requests per second hitting the entry proxy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total{proxy=\"entry\"}[15s])",
          "legendFormat": "entry requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Request Rate (per instance)",
      "description": "HTTP requests per second per worker node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total{proxy=\"worker\"}[15s])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Entry — Denied Requests",
      "description": "Requests denied at the entry proxy (auth failures + rate limit hits)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_denied_req_total{proxy=\"entry\"}[15s])",
          "legendFormat": "denied/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Rate Limit Denials (per instance)",
      "description": "Requests denied by per-worker global rate limit (429s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_denied_req_total{proxy=\"worker\"}[15s])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Entry — 4xx Response Rate",
      "description": "All 4xx responses from the entry proxy (auth failures + rate limit denials)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_responses_total{proxy=\"entry\",code=\"4xx\"}[15s])",
          "legendFormat": "4xx/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Backend — Response Time",
      "description": "Average response time from osu.ppy.sh upstream",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "fixedColor": "green", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "haproxy_backend_response_time_average_seconds{proxy=\"osu_upstream\"}",
          "legendFormat": "{{instance}} avg response time",
          "refId": "A"
        }
      ]
    }
