{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Entry — Request Rate",
      "description": "Total HTTP requests per second hitting the entry proxy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total{proxy=\"entry\"}[5m])",
          "legendFormat": "entry requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Request Rate (per instance)",
      "description": "HTTP requests per second per worker node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total{proxy=\"worker\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Entry — Rate Limit Denials",
      "description": "Requests denied by per-token rate limit (429s). Uses denied_req_total which only counts http-request deny, not auth returns.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_denied_req_total{proxy=\"entry\"}[5m])",
          "legendFormat": "rate-limited/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Rate Limit Denials (per instance)",
      "description": "Requests denied by per-worker global rate limit (429s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_denied_req_total{proxy=\"worker\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Entry — Auth Failures (401s)",
      "description": "Requests rejected for invalid/missing proxy secret. Derived from 4xx total minus denied_req (which only counts rate limits).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_responses_total{proxy=\"entry\",code=\"4xx\"}[5m]) - rate(haproxy_frontend_denied_req_total{proxy=\"entry\"}[5m])",
          "legendFormat": "auth failures/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Backend — Response Time",
      "description": "Average response time from osu.ppy.sh upstream",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "fixedColor": "green", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "haproxy_backend_response_time_average_seconds{proxy=\"osu_upstream\"}",
          "legendFormat": "{{instance}} avg response time",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["haproxy", "osu-proxy"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "osu! API Proxy",
  "uid": "osu-proxy-haproxy",
  "version": 1
}
