{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Entry — Request Rate",
      "description": "Total HTTP requests per second hitting the entry proxy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total{proxy=\"entry\"}[15s])",
          "legendFormat": "entry requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Request Rate (per instance)",
      "description": "HTTP requests per second per worker node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total{proxy=\"worker\"}[15s])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Entry — Denied Requests",
      "description": "Requests denied at the entry proxy (auth failures + rate limit hits)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_denied_req_total{proxy=\"entry\"}[15s])",
          "legendFormat": "denied/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Rate Limit Denials (per instance)",
      "description": "Requests denied by per-worker global rate limit (429s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_denied_req_total{proxy=\"worker\"}[15s])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Entry — Response Codes (via mtail)",
      "description": "Per-status-code response count in 15 s windows from HAProxy access logs. Separates 401 (auth) from 429 (rate limit) and 200 (success).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "increase(haproxy_http_responses_total{frontend=\"entry\"}[15s]) > 0",
          "legendFormat": "{{status}}",
          "interval": "15s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Response Codes (via mtail)",
      "description": "Per-status-code response count in 15 s windows across all workers",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (status) (increase(haproxy_http_responses_total{frontend=\"worker\"}[15s])) > 0",
          "legendFormat": "{{status}}",
          "interval": "15s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Workers — Rate Limit Utilization",
      "description": "Percentage of each worker's global rate limit currently used (threshold: 130 req/60s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          },
          "max": 120
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total{proxy=\"worker\"}[15s]) * 60 / 130 * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Backend — Response Time",
      "description": "Average response time from osu.ppy.sh upstream",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "fixedColor": "green", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "haproxy_backend_response_time_average_seconds{proxy=\"osu_upstream\"}",
          "legendFormat": "{{instance}} avg response time",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["haproxy", "osu-proxy"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "osu! API Proxy",
  "uid": "osu-proxy-haproxy",
  "version": 1
}
